TELEGRAM_BOT_TOKEN=0000000000:replace_me
CHAD_AI_API_KEY=replace_me
CHAD_AI_BASE_URL=https://ask.chadgpt.ru/api/v1
CHAD_AI_MODEL=gpt-5.4-thinking
CHAD_INTENT_MODEL=gpt-5-nano
CHAD_IMAGE_BASE_URL=https://ask.chadgpt.ru
CHAD_IMAGE_MODEL=gpt-img-2
CHAD_IMAGE_ASPECT_RATIO=1:1
CHAD_IMAGE_TIMEOUT_SECONDS=45
CHAD_IMAGE_CHECK_INTERVAL_SECONDS=2
CHAD_IMAGE_MAX_WAIT_SECONDS=90
CHAD_IMAGE_INTENT_MODEL=gpt-5-nano
CHAD_IMAGE_INTENT_TIMEOUT_SECONDS=1.2
CHAD_IMAGE_INTENT_THRESHOLD=7

# Exactly 3 allowed users, comma separated.
ALLOWED_USER_IDS=111111111,222222222,333333333
# Allowed group/supergroup chat IDs.
ALLOWED_CHAT_IDS=-1001234567890

TZ=Europe/Moscow
DAILY_PROGRESS_CHECK_HOUR=10
DAILY_PROGRESS_CHECK_MINUTE=0
REMINDER_INTERVAL_MINUTES=180
GROUP_COOLDOWN_SECONDS=45
GROUP_CONTEXT_PROBABILITY=0.25
GROUP_ACTIVE_WINDOW_SECONDS=420
GROUP_ACTIVE_CONTEXT_PROBABILITY=0.60
GROUP_INTENT_SCORE_THRESHOLD=7
GROUP_INTENT_TIMEOUT_SECONDS=1.4
MAX_REPLY_CHARS=3200

GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json
GOOGLE_SHEET_ID=replace_with_sheet_id

MEMPALACE_ENABLED=true
MEMPALACE_WING_PREFIX=workshop
MEMPALACE_PALACE_DIR=data/mempalace-palace
MEMORY_RERANK_ENABLED=false
MEMORY_RERANK_MIN_CANDIDATES=4
MEMORY_RERANK_CANDIDATE_LIMIT=8
MEMORY_RERANK_FINAL_LIMIT=3
MEMORY_RERANK_TIMEOUT_SECONDS=1.8
STARTUP_SELFTEST_ENABLED=true
STARTUP_SELFTEST_FAIL_FAST=false
STARTUP_SELFTEST_VALIDATOR_MODEL=gpt-5.4-thinking
STARTUP_SELFTEST_TIMEOUT_SECONDS=18
